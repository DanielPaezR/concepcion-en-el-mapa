{
  "name": "concepcion-en-el-mapa",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:admin": "npm run dev --workspace=frontend-admin",
    "dev:turista": "npm run dev --workspace=frontend-turista",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:admin\" \"npm run dev:turista\"",
    "setup": "npm install && cd database/scripts && psql -f 01_create_tables.sql"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}